NODE_ENV=development

# API (Render / apps/api)
PORT=4000
# Usa el dominio principal y el de staging que realmente controles.
CORS_ALLOWED_ORIGINS=https://www.serviciosdigitales.mx,https://app.serviciosdigitales.mx,https://clientes.serviciosdigitales.mx
BASE_DOMAIN=serviciosdigitales.mx,serviciosdigitalesmx.dev
APP_URL=https://www.serviciosdigitales.mx
API_NAME=Sr. Fix API
JWT_SECRET=generate-a-secure-secret-here
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Web public (Vercel / apps/web-public)
NEXT_PUBLIC_API_URL=https://api.serviciosdigitales.mx
NEXT_PUBLIC_WEB_ADMIN_URL=https://app.serviciosdigitales.mx
NEXT_PUBLIC_BASE_DOMAIN=serviciosdigitales.mx
NEXT_PUBLIC_HUB_NAME=Hub operativo
NEXT_PUBLIC_TENANT_LANDING_URL_TEMPLATE=/{tenant}
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
NEXT_PUBLIC_SAAS_BRAND_NAME=Sr. Fix
NEXT_PUBLIC_SAAS_LEGAL_NAME=Servicios Digitales MX
NEXT_PUBLIC_SAAS_BRAND_SHORT=SF
NEXT_PUBLIC_SAAS_DEMO_URL=https://clientes.serviciosdigitales.mx
NEXT_PUBLIC_SAAS_CONTACT_EMAIL=contacto@serviciosdigitales.mx
NEXT_PUBLIC_SAAS_CONTACT_PHONE=+52 8129716587

# Web admin (Vercel / apps/web-admin)
NEXT_PUBLIC_API_URL=https://api.serviciosdigitales.mx
NEXT_PUBLIC_AUTH_TOKEN_KEY=srfix_auth_token
NEXT_PUBLIC_DEFAULT_TENANT_ID=demo
NEXT_PUBLIC_DEFAULT_TENANT_NAME=Taller Demo
NEXT_PUBLIC_TENANT_BRAND_NAME=Sr. Fix Admin
NEXT_PUBLIC_THEME_PRIMARY=#22d3ee
NEXT_PUBLIC_THEME_SECONDARY=#0f172a
NEXT_PUBLIC_THEME_ACCENT=#34d399

# Web clientes (Vercel / apps/web-clientes)
NEXT_PUBLIC_CUSTOMER_PORTAL_NAME=Portal de Seguimiento
NEXT_PUBLIC_WORKSHOP_NAME=Sr. Fix
NEXT_PUBLIC_CUSTOMER_SUPPORT_EMAIL=soporte@serviciosdigitales.mx
NEXT_PUBLIC_CUSTOMER_TRACKING_URL=https://clientes.serviciosdigitales.mx
