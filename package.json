{
  "name": "sdmx-monorepo",
  "private": true,
  "packageManager": "npm@10.8.2",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "dev:frontend": "turbo run dev --filter=web",
    "dev:backend": "turbo run dev --filter=backend-api",
    "audit:source-of-truth": "bash scripts/audit-source-of-truth.sh",
    "audit:auth-boundaries": "bash scripts/audit-auth-boundaries.sh",
    "audit:production-bundle": "bash scripts/audit-production-bundle.sh"
  },
  "devDependencies": {
    "turbo": "^2.9.6"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.19",
    "@nestjs/core": "^11.1.19",
    "@sdmx/contracts": "^1.0.0"
  }
}
