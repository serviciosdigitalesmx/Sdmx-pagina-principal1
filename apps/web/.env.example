# ===== API Configuration =====
# Backend API URL (without /api suffix)
NEXT_PUBLIC_API_URL=http://localhost:5001

# ===== Supabase Configuration (Public/Client Keys Only) =====
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ===== Application URLs =====
# Frontend application URL for client-side redirects
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ===== Server-Side Only Configuration =====
# These should NEVER be exposed in client-side code
# SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ===== Stripe Configuration (Optional) =====
# Only if using Stripe for payments
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# NEXT_PUBLIC_STRIPE_PRICE_BASIC=price_...
# NEXT_PUBLIC_STRIPE_PRICE_PRO=price_...
# NEXT_PUBLIC_STRIPE_PRICE_SCALE=price_...
